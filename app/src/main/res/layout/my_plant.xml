<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgcolor"
    android:fillViewport="true"
    android:overScrollMode="always">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@null"
                android:contentDescription="Back"
                android:padding="0dp"
                android:src="@drawable/weui_arrow_filled__1_" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Minu taim"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Plant Picture -->
        <FrameLayout
            android:id="@+id/btnTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="200dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/search_view_bg">

            <ImageView
                android:id="@+id/selectedPlantImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:contentDescription="@string/selected_plant_image" />
        </FrameLayout>

        <!-- Nickname field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nickname_label"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editNickname"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/search_view_bg"
            android:paddingHorizontal="12dp"
            android:inputType="textPersonName"
            android:hint="@string/enter_nickname"
            android:autofillHints="username"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"
            android:enabled="false"
            android:focusable="false"
            android:cursorVisible="false" />

        <!-- Type field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_label"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editSpecies"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/search_view_bg"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:hint="@string/enter_species"
            android:autofillHints="off"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"
            android:enabled="false"
            android:focusable="false"
            android:cursorVisible="false" />

        <!-- Description field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/description_label"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editDescription"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/search_view_bg"
            android:padding="12dp"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:hint="@string/enter_description"
            android:autofillHints="off"
            android:textColor="@color/black"
            android:layout_marginBottom="24dp"
            android:enabled="false"
            android:focusable="false"
            android:cursorVisible="false" />


        <!-- Horizontal container for control buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            style="?android:attr/buttonBarStyle">

            <!-- Water button (kasta) -->
            <Button
                android:id="@+id/btnWater"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/btncolor"
                android:textColor="@color/white"
                android:text="Kasta"
                android:textAllCaps="false"
                android:textSize="20sp"
                style="?android:attr/buttonBarButtonStyle"
                app:cornerRadius="12dp"
                android:minHeight="48dp"
                android:minWidth="48dp" />

            <!-- Edit button (muuta) -->
            <Button
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="@color/btncolor"
                android:text="Muuta"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="20sp"
                style="?android:attr/buttonBarButtonStyle"
                app:cornerRadius="12dp"
                android:minHeight="48dp"
                android:minWidth="48dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/search_view_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Hooldusajalugu"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TableLayout
                android:id="@+id/tableCareHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/btncolor"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="8dp"
                        android:text="Tüüp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="8dp"
                        android:text="Kuupäev"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </TableRow>
            </TableLayout>
        </LinearLayout>


    </LinearLayout>
</androidx.core.widget.NestedScrollView>
