<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgcolor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/titleText"
            style="@style/ScreenHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tere"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Today (expanded by default) -->
        <LinearLayout
            android:id="@+id/headerToday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/titleToday"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/today"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/inter_28pt_regular"/>
            <ImageView
                android:id="@+id/toggleToday"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/vector"
                app:tint="@color/daark_green"
                android:contentDescription="@string/toggle"
                />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/sectionToday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:id="@+id/containerToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- This week (collapsed by default) -->
        <LinearLayout
            android:id="@+id/headerWeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/titleWeek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/this_week"
                android:textSize="20sp"
                android:fontFamily="@font/inter_28pt_regular"
                android:textStyle="bold"
                android:textColor="@color/black" />
            <ImageView
                android:id="@+id/toggleWeek"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/vector"
                app:tint="@color/daark_green"
                android:contentDescription="@string/toggle"
                 />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/sectionNext7Days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            >
            <LinearLayout
                android:id="@+id/containerNext7Days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Later (collapsed by default) -->
        <LinearLayout
            android:id="@+id/headerLater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/titleLater"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hiljem"
                android:textSize="20sp"
                android:fontFamily="@font/inter_28pt_regular"
                android:textStyle="bold"
                android:textColor="@color/black" />
            <ImageView
                android:id="@+id/toggleLater"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/vector"
                app:tint="@color/daark_green"
                android:contentDescription="@string/toggle"
                />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/sectionLater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            >
            <LinearLayout
                android:id="@+id/containerLater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- No upcoming care message -->
        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/teie_taimed_on_hoolitsetud"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:padding="24dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
