<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgcolor">

    <!-- КНОПКА НАЗАД (Стрелка) -->
    <ImageView
        android:id="@+id/backButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:scaleType="centerInside"
        android:contentDescription="@string/backbutton"
        app:layout_constraintBottom_toBottomOf="@+id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/titleText"
        app:srcCompat="@drawable/weui_arrow_filled__1_"
         />

    <!-- ЗАГОЛОВОК СТРАНИЦЫ -->
    <TextView
        android:id="@+id/titleText"
        style="@style/ScreenHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text="@string/encyclopedia_title"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/backButton"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- КАРТОЧКА С КОНТЕНТОМ (Занимает всё свободное место до низа экрана) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/contentCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#C5D192"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Изображение растения -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/plantImage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/plant"
                    app:shapeAppearanceOverlay="@style/rounded_corners"
                     />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/commonNameText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/common_name"
                        android:textColor="@color/daark_green"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/favoriteButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_gravity="center_vertical"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@null"
                        android:src="@drawable/ic_heart_outline"
                        app:tint="@color/daark_green"
                        android:contentDescription="@string/add_to_favorites" />

                </LinearLayout>

                <TextView
                    android:id="@+id/scientificNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:text="@string/scientific_name"
                    android:textColor="@color/daark_green"
                    android:textSize="18sp"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/descriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/inter_28pt_regular"
                    android:text="@string/description_goes_here"
                    android:textColor="@color/daark_green" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/dark_rounded_rect"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/care_level"
                        android:textColor="@color/tekstEnts"
                        android:textStyle="bold"
                        />

                    <TextView
                        android:id="@+id/careLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/medium"
                        android:textColor="@color/tekstEnts" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/toxic_to_pets"
                        android:textColor="@color/tekstEnts"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/toxicToPets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no"
                        android:textColor="@color/tekstEnts" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/sunlight_requirement"
                        android:textStyle="bold"

                        android:textColor="@color/tekstEnts" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/sun1"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_sun"
                            app:tint="@color/tekstEnts"
                            android:alpha="0.3"
                            android:contentDescription="@string/sun_icon"
                            />
                        <ImageView
                            android:id="@+id/sun2"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_sun"
                            app:tint="@color/tekstEnts"
                            android:alpha="0.3"
                            android:contentDescription="@string/sun_icon"
                        />
                        <ImageView
                            android:id="@+id/sun3"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_sun"
                            app:tint="@color/tekstEnts"
                            android:alpha="0.3"
                            android:contentDescription="@string/sun_icon"
                            />
                        <ImageView
                            android:id="@+id/sun4"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_sun"
                            app:tint="@color/tekstEnts"
                            android:alpha="0.3"
                            android:contentDescription="@string/sun_icon"
                            />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/water_requirement"
                        android:textStyle="bold"
                        android:textColor="@color/tekstEnts" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/drop1"
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_marginEnd="11dp"
                            android:src="@drawable/ic_drop"
                            app:tint="@color/tekstEnts"
                            android:alpha="0.3"
                            android:contentDescription="@string/sun_icon"
                            />
                        <ImageView
                            android:id="@+id/drop2"
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_marginEnd="11dp"
                            android:src="@drawable/ic_drop"
                            app:tint="@color/tekstEnts"
                            android:alpha="0.3"
                            android:contentDescription="@string/sun_icon"
                            />
                        <ImageView
                            android:id="@+id/drop3"
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_marginEnd="11dp"
                            android:src="@drawable/ic_drop"
                            app:tint="@color/tekstEnts"
                            android:alpha="0.3"
                            android:contentDescription="@string/sun_icon"
                            />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
